APP_NAME=CraftKeeper
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

# Task 20: comma-separated IPs/CIDRs of a reverse proxy/load balancer
# this app is reachable behind, or the literal '*' to trust any proxy
# (safe ONLY when this container itself is never directly reachable from
# an untrusted network — e.g. it sits behind a Docker/Compose network
# boundary with no port published to the host). Left unset (the
# default), NO proxy is trusted and $request->isSecure()/getClientIp()
# reflect the raw connection exactly — which also means
# SESSION_SECURE_COOKIE's own auto-detection and the Strict-Transport-
# Security header (App\Http\Middleware\SecurityHeaders) never activate
# behind a TLS-terminating proxy until this is set correctly.
# TRUSTED_PROXIES=

# Extra hostnames this installation may legitimately be reached on, beyond
# the host in APP_URL. Comma-separated, exact hostnames — no scheme, no
# port: "craftkeeper.lan,192.168.1.50".
#
# Absolute URLs (password-reset and email-verification links especially)
# are built from the incoming request's Host header, so an unchecked Host
# lets an attacker mail a working reset link pointing at their own domain.
# Once APP_URL names a real host, CraftKeeper only answers to that host,
# anything listed here, and the loopback names — everything else gets a
# 400. Add an entry here if you also reach the panel by LAN address or a
# second domain.
#
# Left unset with APP_URL still on its default, no host check is applied
# at all: nothing has declared where this installation actually lives, and
# guessing would reject the LAN address or container name you are probably
# using. Setting APP_URL is what turns the check on.
# TRUSTED_HOSTS=

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

# Task 12 is the first frontend consumer of Reverb (see Task 5's
# decisions.md entry forecasting this) — server.console and operations.{id}
# are subscribed to from the Console/OperationProgress UI. These are a
# real, generated app id/key/secret for LOCAL DEVELOPMENT ONLY (Reverb app
# keys, unlike the secret, are not sensitive — they identify a websocket
# client the same way a Pusher app key does). No supervisor in this repo
# runs `reverb:start` outside the Docker image (see docker/supervisor/
# supervisord.conf), so locally/in CI the frontend's Echo client simply
# cannot open a socket and reports its honest "unavailable" connection
# state — this is what tests/e2e's reconnect-state assertions exercise.
REVERB_APP_ID=843038
REVERB_APP_KEY=lidGH6EwMop5abo3E6hY
REVERB_APP_SECRET=HNBd2ErQch4yGcdWrETU
REVERB_HOST="localhost"
REVERB_PORT=8080
REVERB_SCHEME=http

VITE_REVERB_APP_KEY="${REVERB_APP_KEY}"
VITE_REVERB_HOST="${REVERB_HOST}"
VITE_REVERB_PORT="${REVERB_PORT}"
VITE_REVERB_SCHEME="${REVERB_SCHEME}"

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"
