{
    "id": "server-properties",
    "title": "Server Properties",
    "format": "properties",
    "fields": [
        {
            "path": "motd",
            "type": "string",
            "title": "MOTD",
            "description": "The message shown in the server list beneath the server name.",
            "default": "A Minecraft Server",
            "restartImpact": "none",
            "risk": "low",
            "allowedValues": null,
            "range": null,
            "secret": false,
            "documentationUrl": "https://minecraft.wiki/w/Server.properties#motd"
        },
        {
            "path": "difficulty",
            "type": "string",
            "title": "Difficulty",
            "description": "Sets how hostile the world is — affects mob damage, hunger, and spawns.",
            "default": "easy",
            "restartImpact": "none",
            "risk": "low",
            "allowedValues": ["peaceful", "easy", "normal", "hard"],
            "range": null,
            "secret": false,
            "documentationUrl": "https://minecraft.wiki/w/Server.properties#difficulty"
        },
        {
