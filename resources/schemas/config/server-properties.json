            "risk": "medium",
            "allowedValues": null,
            "range": { "min": 3, "max": 32 },
            "secret": false,
            "documentationUrl": "https://minecraft.wiki/w/Server.properties#view-distance"
        },
        {
            "path": "simulation-distance",
            "type": "integer",
