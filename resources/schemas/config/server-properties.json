            "type": "string",
            "title": "Default game mode",
            "description": "The game mode newly joined players are given.",
            "default": "survival",
            "restartImpact": "none",
            "risk": "low",
            "allowedValues": ["survival", "creative", "adventure", "spectator"],
            "range": null,
            "secret": false,
            "documentationUrl": "https://minecraft.wiki/w/Server.properties#gamemode"
        },
        {
