{
    "id": "paper-global",
    "title": "Paper Global Configuration",
    "format": "yaml",
    "fields": [
        {
            "path": "proxies.velocity.enabled",
            "type": "boolean",
            "title": "Velocity proxy support",
            "description": "Accepts connections forwarded by a Velocity proxy using the modern forwarding protocol.",
            "default": false,
            "restartImpact": "restart",
            "risk": "high",
            "allowedValues": null,
            "range": null,
            "secret": false,
            "documentationUrl": "https://docs.papermc.io/paper/reference/global-configuration/#proxies.velocity.enabled"
        },
        {
            "path": "proxies.velocity.online-mode",
            "type": "boolean",
            "title": "Velocity online mode",
            "description": "Whether Velocity's forwarded connections are treated as already authenticated. Must match the proxy's own online-mode setting.",
            "default": false,
            "restartImpact": "restart",
            "risk": "high",
            "allowedValues": null,
            "range": null,
            "secret": false,
            "documentationUrl": "https://docs.papermc.io/paper/reference/global-configuration/#proxies.velocity.online-mode"
        },
        {
            "path": "proxies.velocity.secret",
            "type": "string",
            "title": "Velocity forwarding secret",
            "description": "The shared secret Velocity signs forwarded connection data with. Must match the proxy's forwarding.secret file exactly. CraftKeeper never displays this value once set.",
            "default": "",
            "restartImpact": "restart",
            "risk": "high",
            "allowedValues": null,
            "range": null,
            "secret": true,
            "documentationUrl": "https://docs.papermc.io/paper/reference/global-configuration/#proxies.velocity.secret"
        },
        {
            "path": "proxies.bungee-cord.online-mode",
            "type": "boolean",
            "title": "BungeeCord online mode",
            "description": "Whether connections forwarded by a BungeeCord/Waterfall proxy are treated as already authenticated.",
            "default": true,
            "restartImpact": "restart",
            "risk": "high",
            "allowedValues": null,
            "range": null,
            "secret": false,
            "documentationUrl": "https://docs.papermc.io/paper/reference/global-configuration/#proxies.bungee-cord.online-mode"
        },
        {
            "path": "proxies.proxy-protocol",
            "type": "boolean",
            "title": "HAProxy PROXY protocol",
            "description": "Accepts the PROXY protocol header from a compatible load balancer/proxy in front of the server.",
            "default": false,
            "restartImpact": "restart",
            "risk": "high",
            "allowedValues": null,
            "range": null,
            "secret": false,
            "documentationUrl": "https://docs.papermc.io/paper/reference/global-configuration/#proxies.proxy-protocol"
        },
        {
            "path": "commands.suggest-player-names-when-null-tab-completions",
            "type": "boolean",
            "title": "Suggest player names on empty tab-completion",
            "description": "Whether commands that would otherwise show no tab-completions suggest online player names instead.",
            "default": true,
            "restartImpact": "reload",
            "risk": "low",
            "allowedValues": null,
            "range": null,
            "secret": false,
            "documentationUrl": "https://docs.papermc.io/paper/reference/global-configuration/#commands.suggest-player-names-when-null-tab-completions"
        },
        {
            "path": "commands.ride-command-allow-player-as-vehicle",
            "type": "boolean",
            "title": "Allow /ride to use a player as the vehicle",
            "description": "Whether the /ride command allows mounting one player onto another.",
            "default": false,
            "restartImpact": "reload",
            "risk": "low",
            "allowedValues": null,
            "range": null,
            "secret": false,
            "documentationUrl": "https://docs.papermc.io/paper/reference/global-configuration/#commands.ride-command-allow-player-as-vehicle"
        },
        {
            "path": "watchdog.early-warning-every",
            "type": "integer",
            "title": "Watchdog early-warning interval",
            "description": "Milliseconds between repeated early-warning dumps once the server appears hung, before the watchdog forcibly restarts it.",
            "default": 5000,
            "restartImpact": "restart",
            "risk": "medium",
            "allowedValues": null,
            "range": { "min": 0, "max": 600000 },
            "secret": false,
            "documentationUrl": "https://docs.papermc.io/paper/reference/global-configuration/#watchdog.early-warning-every"
        },
        {
            "path": "watchdog.early-warning-delay",
            "type": "integer",
            "title": "Watchdog early-warning delay",
            "description": "Milliseconds of unresponsiveness before the watchdog logs its first early warning.",
            "default": 10000,
            "restartImpact": "restart",
            "risk": "medium",
            "allowedValues": null,
            "range": { "min": 0, "max": 600000 },
            "secret": false,
            "documentationUrl": "https://docs.papermc.io/paper/reference/global-configuration/#watchdog.early-warning-delay"
        },
        {
            "path": "packet-limiter.all-packets.max-packet-rate",
            "type": "number",
            "title": "Global packet rate limit",
            "description": "Maximum packets per second, per player, before the configured limiter action is taken.",
            "default": 500,
            "restartImpact": "reload",
            "risk": "medium",
            "allowedValues": null,
            "range": { "min": 1, "max": null },
            "secret": false,
            "documentationUrl": "https://docs.papermc.io/paper/reference/global-configuration/#packet-limiter.all-packets.max-packet-rate"
        },
        {
            "path": "packet-limiter.all-packets.interval",
            "type": "number",
            "title": "Global packet limiter interval",
            "description": "The interval, in seconds, over which the packet rate limit is measured.",
            "default": 7.0,
            "restartImpact": "reload",
            "risk": "low",
            "allowedValues": null,
            "range": { "min": 0, "max": null },
            "secret": false,
            "documentationUrl": "https://docs.papermc.io/paper/reference/global-configuration/#packet-limiter.all-packets.interval"
        },
        {
            "path": "packet-limiter.kick-message",
            "type": "string",
            "title": "Packet limiter kick message",
            "description": "The message shown to a player disconnected for exceeding a packet rate limit.",
            "default": "Disconnected due to a network protocol error",
            "restartImpact": "reload",
            "risk": "low",
            "allowedValues": null,
            "range": null,
            "secret": false,
            "documentationUrl": "https://docs.papermc.io/paper/reference/global-configuration/#packet-limiter.kick-message"
        },
        {
            "path": "spam-limiter.tab-spam-limit",
            "type": "integer",
            "title": "Tab-completion spam limit",
            "description": "How many tab-completion requests a player may send before being flagged as spamming.",
            "default": 500,
            "restartImpact": "reload",
            "risk": "low",
            "allowedValues": null,
            "range": { "min": 0, "max": null },
            "secret": false,
            "documentationUrl": "https://docs.papermc.io/paper/reference/global-configuration/#spam-limiter.tab-spam-limit"
        },
        {
            "path": "spam-limiter.recipe-spam-limit",
            "type": "integer",
            "title": "Recipe-book spam limit",
            "description": "How many recipe-book requests a player may send before being flagged as spamming.",
            "default": 20,
            "restartImpact": "reload",
            "risk": "low",
            "allowedValues": null,
            "range": { "min": 0, "max": null },
            "secret": false,
            "documentationUrl": "https://docs.papermc.io/paper/reference/global-configuration/#spam-limiter.recipe-spam-limit"
        },
        {
            "path": "chunk-loading-basic.player-max-chunk-load-rate",
            "type": "number",
            "title": "Max chunk load rate per player",
            "description": "Maximum chunks per second sent to a single player. -1 disables the limit.",
            "default": -1.0,
            "restartImpact": "reload",
            "risk": "medium",
            "allowedValues": null,
            "range": null,
            "secret": false,
            "documentationUrl": "https://docs.papermc.io/paper/reference/global-configuration/#chunk-loading-basic.player-max-chunk-load-rate"
        },
        {
            "path": "chunk-loading-basic.player-max-chunk-send-rate",
            "type": "number",
            "title": "Max chunk send rate per player",
            "description": "Maximum chunks per second the server will send to a single player's client.",
            "default": 75.0,
            "restartImpact": "reload",
            "risk": "medium",
            "allowedValues": null,
            "range": null,
            "secret": false,
            "documentationUrl": "https://docs.papermc.io/paper/reference/global-configuration/#chunk-loading-basic.player-max-chunk-send-rate"
        },
        {
            "path": "collisions.enable-player-collisions",
            "type": "boolean",
            "title": "Enable player collisions",
            "description": "Whether players physically collide with each other.",
            "default": true,
            "restartImpact": "reload",
            "risk": "low",
            "allowedValues": null,
            "range": null,
            "secret": false,
            "documentationUrl": "https://docs.papermc.io/paper/reference/global-configuration/#collisions.enable-player-collisions"
        },
        {
            "path": "misc.max-joins-per-tick",
            "type": "integer",
            "title": "Max joins per tick",
            "description": "Maximum number of players allowed to complete login in a single server tick, smoothing out join-flood spikes.",
            "default": 3,
            "restartImpact": "reload",
            "risk": "low",
            "allowedValues": null,
            "range": { "min": 0, "max": null },
            "secret": false,
            "documentationUrl": "https://docs.papermc.io/paper/reference/global-configuration/#misc.max-joins-per-tick"
        },
        {
            "path": "update-checker.enabled",
            "type": "boolean",
            "title": "Update checker",
            "description": "Whether Paper checks for and logs available server-software updates.",
            "default": true,
            "restartImpact": "reload",
            "risk": "low",
            "allowedValues": null,
            "range": null,
            "secret": false,
            "documentationUrl": "https://docs.papermc.io/paper/reference/global-configuration/#update-checker.enabled"
        }
    ]
}
